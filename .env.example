# Polling interval in seconds (default: 86400 = daily)
IVORIS_INTERVAL_SECONDS=86400

# Input file with mocked ivoris file entries
IVORIS_SOURCE_CSV=data/input/ivoris_file_entries.csv

# Output CSV for extracted data (ML0 direct storage)
IVORIS_OUTPUT_CSV=data/output/ivoris_extract.csv

# Run exactly one extraction cycle and exit (1/true/yes)
IVORIS_RUN_ONCE=true
